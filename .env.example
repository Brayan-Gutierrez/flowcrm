# ============================================================
# FlowCRM — Variables de entorno
# ------------------------------------------------------------
# La app FUNCIONA SIN configurar nada (modo demo con datos mock).
# Para conectar Supabase real, copia este archivo a .env.local
# y completa los valores.
# ============================================================

# Supabase (opcional — si no se define, se usa el modo demo)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Activa la fuente de datos: "mock" (por defecto) o "supabase"
NEXT_PUBLIC_DATA_SOURCE=mock
